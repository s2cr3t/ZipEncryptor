<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>850</width>
    <height>650</height>
   </rect>
  </property>
  <property name="minimumSize">
   <size>
    <width>750</width>
    <height>550</height>
   </size>
  </property>
  <property name="windowTitle">
   <string>ZIP文件加密工具 - 个人版</string>
  </property>
  <property name="styleSheet">
   <string notr="true">/* 主窗口样式 */
QMainWindow {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
                stop:0 #f8f9fa, stop:1 #e9ecef);
    color: #212529;
}

/* 字体设置 */
QWidget {
    font-family: "Microsoft YaHei UI", "Segoe UI", "Arial", sans-serif;
    font-size: 9pt;
    color: #212529;
}

/* 主要按钮样式 */
QPushButton {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                stop:0 #4285f4, stop:1 #3367d6);
    color: white;
    border: none;
    border-radius: 6px;
    padding: 8px 16px;
    font-weight: 500;
    font-size: 9pt;
    min-height: 16px;
    min-width: 80px;
}

QPushButton:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                stop:0 #5a95f5, stop:1 #4285f4);
}

QPushButton:pressed {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                stop:0 #3367d6, stop:1 #2c5aa0);
}

QPushButton:disabled {
    background: #e0e0e0;
    color: #9e9e9e;
}

/* 次要按钮样式 */
QPushButton[objectName="refreshButton"],
QPushButton[objectName="selectAllButton"],
QPushButton[objectName="deselectAllButton"] {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                stop:0 #ffffff, stop:1 #f8f9fa);
    color: #495057;
    border: 1px solid #dee2e6;
    padding: 6px 12px;
    min-height: 14px;
    min-width: 70px;
}

QPushButton[objectName="refreshButton"]:hover,
QPushButton[objectName="selectAllButton"]:hover,
QPushButton[objectName="deselectAllButton"]:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                stop:0 #f8f9fa, stop:1 #e9ecef);
    border-color: #adb5bd;
}

/* 危险按钮样式 */
QPushButton[objectName="cancelButton"] {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                stop:0 #dc3545, stop:1 #c82333);
    padding: 10px 20px;
    min-height: 18px;
    min-width: 90px;
    font-weight: 600;
}

QPushButton[objectName="cancelButton"]:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                stop:0 #e4606d, stop:1 #dc3545);
}

/* 主要操作按钮 */
QPushButton[objectName="encryptButton"] {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                stop:0 #28a745, stop:1 #1e7e34);
    padding: 10px 20px;
    min-height: 18px;
    min-width: 100px;
    font-weight: 600;
    font-size: 10pt;
}

QPushButton[objectName="encryptButton"]:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                stop:0 #34ce57, stop:1 #28a745);
}

/* 浏览按钮 */
QPushButton[objectName="browseButton"] {
    padding: 8px 16px;
    min-height: 16px;
    min-width: 80px;
}

/* 输入框样式 */
QLineEdit {
    background: white;
    border: 1px solid #ced4da;
    border-radius: 4px;
    padding: 8px 12px;
    font-size: 9pt;
    selection-background-color: #4285f4;
}

QLineEdit:focus {
    border-color: #4285f4;
    background: #ffffff;
}

QLineEdit:read-only {
    background: #f8f9fa;
    color: #6c757d;
}

/* 进度条样式 */
QProgressBar {
    border: 1px solid #dee2e6;
    border-radius: 4px;
    background: #f8f9fa;
    text-align: center;
    font-weight: 500;
    font-size: 9pt;
    color: #495057;
    height: 20px;
}

QProgressBar::chunk {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                stop:0 #4285f4, stop:0.5 #34a853, stop:1 #4285f4);
    border-radius: 3px;
    margin: 1px;
}

/* 分组框样式 */
QGroupBox {
    font-weight: 600;
    font-size: 10pt;
    color: #495057;
    border: 1px solid #dee2e6;
    border-radius: 8px;
    margin-top: 12px;
    padding-top: 8px;
    background: rgba(255,255,255,0.7);
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 4px 12px;
    background: white;
    border: 1px solid #dee2e6;
    border-radius: 4px;
    color: #495057;
    font-weight: 600;
    margin-left: 8px;
}

/* 标签样式 */
QLabel {
    color: #495057;
    font-weight: 400;
}

/* 列表控件样式 */
QListWidget {
    background: white;
    border: 1px solid #dee2e6;
    border-radius: 4px;
    padding: 4px;
    outline: none;
    selection-background-color: transparent;
}

QListWidget::item {
    background: transparent;
    border: none;
    border-radius: 3px;
    padding: 8px 12px;
    margin: 1px 0px;
    color: #495057;
}

QListWidget::item:selected {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                stop:0 rgba(66,133,244,0.1), stop:1 rgba(66,133,244,0.05));
    color: #4285f4;
    font-weight: 500;
}

QListWidget::item:hover {
    background: rgba(66,133,244,0.05);
}

/* 复选框样式 */
QCheckBox {
    color: #495057;
    font-weight: 400;
    spacing: 6px;
}

QCheckBox::indicator {
    width: 16px;
    height: 16px;
    border-radius: 3px;
    border: 1px solid #ced4da;
    background: white;
}

QCheckBox::indicator:checked {
    background: #4285f4;
    border-color: #4285f4;
}

QCheckBox::indicator:hover {
    border-color: #4285f4;
}

/* 菜单栏样式 */
QMenuBar {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                stop:0 #ffffff, stop:1 #f8f9fa);
    border-bottom: 1px solid #dee2e6;
    padding: 2px;
}

QMenuBar::item {
    background: transparent;
    padding: 6px 12px;
    border-radius: 4px;
    color: #495057;
    font-weight: 400;
}

QMenuBar::item:selected {
    background: rgba(66,133,244,0.1);
    color: #4285f4;
}

QMenu {
    background: white;
    border: 1px solid #dee2e6;
    border-radius: 6px;
    padding: 4px;
}

QMenu::item {
    padding: 6px 12px;
    border-radius: 4px;
    color: #495057;
}

QMenu::item:selected {
    background: rgba(66,133,244,0.1);
    color: #4285f4;
}

/* 状态栏样式 */
QStatusBar {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                stop:0 #f8f9fa, stop:1 #e9ecef);
    border-top: 1px solid #dee2e6;
    color: #6c757d;
    font-weight: 400;
    padding: 4px;
}

/* 滚动条样式 */
QScrollBar:vertical {
    border: none;
    background: #f8f9fa;
    width: 10px;
    border-radius: 5px;
}

QScrollBar::handle:vertical {
    background: #adb5bd;
    border-radius: 5px;
    min-height: 20px;
    margin: 1px;
}

QScrollBar::handle:vertical:hover {
    background: #6c757d;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0px;
}
</string>
  </property>
  <widget class="QWidget" name="centralwidget">
   <layout class="QVBoxLayout" name="verticalLayout_main">
    <property name="spacing">
     <number>12</number>
    </property>
    <property name="leftMargin">
     <number>16</number>
    </property>
    <property name="topMargin">
     <number>16</number>
    </property>
    <property name="rightMargin">
     <number>16</number>
    </property>
    <property name="bottomMargin">
     <number>16</number>
    </property>
    
    <!-- 文件选择区域 -->
    <item>
     <widget class="QGroupBox" name="fileSelectionGroup">
      <property name="title">
       <string>文件选择</string>
      </property>
      <layout class="QVBoxLayout" name="fileSelectionLayout">
       <property name="spacing">
        <number>8</number>
       </property>
       <item>
        <layout class="QHBoxLayout" name="directoryLayout">
         <property name="spacing">
          <number>8</number>
         </property>
         <item>
          <widget class="QLineEdit" name="directoryLineEdit">
           <property name="placeholderText">
            <string>请选择包含ZIP文件的目录路径...</string>
           </property>
           <property name="readOnly">
            <bool>true</bool>
           </property>
           <property name="toolTip">
            <string>选择包含需要加密的ZIP文件的目录</string>
           </property>
          </widget>
         </item>
         <item>
          <widget class="QPushButton" name="browseButton">
           <property name="text">
            <string>浏览...</string>
           </property>
           <property name="toolTip">
            <string>点击选择目录</string>
           </property>
          </widget>
         </item>
        </layout>
       </item>
      </layout>
     </widget>
    </item>
    
    <!-- ZIP文件列表区域 -->
    <item>
     <widget class="QGroupBox" name="fileListGroup">
      <property name="title">
       <string>ZIP文件列表</string>
      </property>
      <layout class="QVBoxLayout" name="fileListLayout">
       <property name="spacing">
        <number>8</number>
       </property>
       <item>
        <widget class="QListWidget" name="fileListWidget">
         <property name="minimumHeight">
          <number>180</number>
         </property>
         <property name="toolTip">
          <string>选择需要加密的ZIP文件（支持多选）</string>
         </property>
        </widget>
       </item>
       <item>
        <layout class="QHBoxLayout" name="fileControlLayout">
         <property name="spacing">
          <number>8</number>
         </property>
         <item>
          <widget class="QPushButton" name="refreshButton">
           <property name="text">
            <string>刷新列表</string>
           </property>
           <property name="toolTip">
            <string>重新扫描目录中的ZIP文件</string>
           </property>
          </widget>
         </item>
         <item>
          <widget class="QPushButton" name="selectAllButton">
           <property name="text">
            <string>全选</string>
           </property>
           <property name="toolTip">
            <string>选择所有ZIP文件</string>
           </property>
          </widget>
         </item>
         <item>
          <widget class="QPushButton" name="deselectAllButton">
           <property name="text">
            <string>取消全选</string>
           </property>
           <property name="toolTip">
            <string>取消选择所有文件</string>
           </property>
          </widget>
         </item>
         <item>
          <spacer name="fileControlSpacer">
           <property name="orientation">
            <enum>Qt::Horizontal</enum>
           </property>
           <property name="sizeHint" stdset="0">
            <size>
             <width>40</width>
             <height>20</height>
            </size>
           </property>
          </spacer>
         </item>
         <item>
          <widget class="QLabel" name="fileCountLabel">
           <property name="text">
            <string>已选择: 0 个文件</string>
           </property>
           <property name="styleSheet">
            <string notr="true">QLabel { color: #6c757d; font-weight: 500; }</string>
           </property>
          </widget>
         </item>
        </layout>
       </item>
      </layout>
     </widget>
    </item>
    
    <!-- 加密设置区域 -->
    <item>
     <widget class="QGroupBox" name="encryptionGroup">
      <property name="title">
       <string>加密设置</string>
      </property>
      <layout class="QGridLayout" name="encryptionLayout">
       <property name="horizontalSpacing">
        <number>12</number>
       </property>
       <property name="verticalSpacing">
        <number>8</number>
       </property>
       <item row="0" column="0">
        <widget class="QLabel" name="passwordLabel">
         <property name="text">
          <string>加密密码:</string>
         </property>
         <property name="styleSheet">
          <string notr="true">QLabel { font-weight: 500; }</string>
         </property>
        </widget>
       </item>
       <item row="0" column="1">
        <widget class="QLineEdit" name="passwordLineEdit">
         <property name="echoMode">
          <enum>QLineEdit::Password</enum>
         </property>
         <property name="placeholderText">
          <string>请输入强密码（建议8位以上）</string>
         </property>
         <property name="toolTip">
          <string>输入用于加密ZIP文件的密码</string>
         </property>
        </widget>
       </item>
       <item row="1" column="0">
        <widget class="QLabel" name="confirmPasswordLabel">
         <property name="text">
          <string>确认密码:</string>
         </property>
         <property name="styleSheet">
          <string notr="true">QLabel { font-weight: 500; }</string>
         </property>
        </widget>
       </item>
       <item row="1" column="1">
        <widget class="QLineEdit" name="confirmPasswordLineEdit">
         <property name="echoMode">
          <enum>QLineEdit::Password</enum>
         </property>
         <property name="placeholderText">
          <string>请再次输入相同的密码进行确认</string>
         </property>
         <property name="toolTip">
          <string>再次输入密码以确认</string>
         </property>
        </widget>
       </item>
       <item row="2" column="1">
        <layout class="QHBoxLayout" name="passwordOptionsLayout">
         <item>
          <widget class="QCheckBox" name="showPasswordCheckBox">
           <property name="text">
            <string>显示密码</string>
           </property>
           <property name="toolTip">
            <string>切换密码的显示/隐藏状态</string>
           </property>
          </widget>
         </item>
         <item>
          <spacer name="passwordOptionsSpacer">
           <property name="orientation">
            <enum>Qt::Horizontal</enum>
           </property>
           <property name="sizeHint" stdset="0">
            <size>
             <width>40</width>
             <height>20</height>
            </size>
           </property>
          </spacer>
         </item>
         <item>
          <widget class="QLabel" name="passwordStrengthLabel">
           <property name="text">
            <string>密码强度: 无</string>
           </property>
           <property name="styleSheet">
            <string notr="true">QLabel { color: #6c757d; font-size: 8pt; }</string>
           </property>
          </widget>
         </item>
        </layout>
       </item>
      </layout>
     </widget>
    </item>
    
    <!-- 进度显示区域 -->
    <item>
     <widget class="QGroupBox" name="progressGroup">
      <property name="title">
       <string>加密进度</string>
      </property>
      <layout class="QVBoxLayout" name="progressLayout">
       <property name="spacing">
        <number>8</number>
       </property>
       <item>
        <widget class="QProgressBar" name="totalProgressBar">
         <property name="value">
          <number>0</number>
         </property>
         <property name="toolTip">
          <string>总体加密进度</string>
         </property>
        </widget>
       </item>
       <item>
        <layout class="QHBoxLayout" name="statusLayout">
         <item>
          <widget class="QLabel" name="statusLabel">
           <property name="text">
            <string>就绪</string>
           </property>
           <property name="styleSheet">
            <string notr="true">QLabel { font-weight: 500; color: #495057; }</string>
           </property>
          </widget>
         </item>
         <item>
          <spacer name="statusSpacer">
           <property name="orientation">
            <enum>Qt::Horizontal</enum>
           </property>
           <property name="sizeHint" stdset="0">
            <size>
             <width>40</width>
             <height>20</height>
            </size>
           </property>
          </spacer>
         </item>
         <item>
          <widget class="QLabel" name="timeLabel">
           <property name="text">
            <string></string>
           </property>
           <property name="styleSheet">
            <string notr="true">QLabel { color: #6c757d; font-size: 8pt; }</string>
           </property>
          </widget>
         </item>
        </layout>
       </item>
      </layout>
     </widget>
    </item>
    
    <!-- 操作按钮区域 -->
    <item>
     <layout class="QHBoxLayout" name="actionLayout">
      <property name="spacing">
       <number>12</number>
      </property>
      <item>
       <spacer name="leftSpacer">
        <property name="orientation">
         <enum>Qt::Horizontal</enum>
        </property>
        <property name="sizeHint" stdset="0">
         <size>
          <width>40</width>
          <height>20</height>
         </size>
        </property>
       </spacer>
      </item>
      <item>
       <widget class="QPushButton" name="encryptButton">
        <property name="text">
         <string>开始加密</string>
        </property>
        <property name="toolTip">
         <string>开始对选中的ZIP文件进行加密</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QPushButton" name="cancelButton">
        <property name="text">
         <string>取消操作</string>
        </property>
        <property name="toolTip">
         <string>取消当前的加密操作</string>
        </property>
       </widget>
      </item>
      <item>
       <spacer name="rightSpacer">
        <property name="orientation">
         <enum>Qt::Horizontal</enum>
        </property>
        <property name="sizeHint" stdset="0">
         <size>
          <width>40</width>
          <height>20</height>
         </size>
        </property>
       </spacer>
      </item>
     </layout>
    </item>
   </layout>
  </widget>
  
  <!-- 菜单栏 -->
  <widget class="QMenuBar" name="menubar">
   <property name="geometry">
    <rect>
     <x>0</x>
     <y>0</y>
     <width>850</width>
     <height>22</height>
    </rect>
   </property>
   <widget class="QMenu" name="fileMenu">
    <property name="title">
     <string>文件(&amp;F)</string>
    </property>
    <addaction name="actionOpen"/>
    <addaction name="separator"/>
    <addaction name="actionExit"/>
   </widget>
   <widget class="QMenu" name="helpMenu">
    <property name="title">
     <string>帮助(&amp;H)</string>
    </property>
    <addaction name="actionAbout"/>
   </widget>
   <addaction name="fileMenu"/>
   <addaction name="helpMenu"/>
  </widget>
  
  <!-- 状态栏 -->
  <widget class="QStatusBar" name="statusbar"/>
  
  <!-- 菜单动作 -->
  <action name="actionOpen">
   <property name="text">
    <string>打开目录(&amp;O)</string>
   </property>
   <property name="shortcut">
    <string>Ctrl+O</string>
   </property>
   <property name="toolTip">
    <string>选择包含ZIP文件的目录</string>
   </property>
  </action>
  <action name="actionExit">
   <property name="text">
    <string>退出(&amp;X)</string>
   </property>
   <property name="shortcut">
    <string>Ctrl+Q</string>
   </property>
  </action>
  <action name="actionAbout">
   <property name="text">
    <string>关于(&amp;A)</string>
   </property>
  </action>
 </widget>
 <resources/>
 <connections/>
</ui>